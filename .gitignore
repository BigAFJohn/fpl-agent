# Virtual environment
.venv/

# Database files (binary, changes every run)
db/*.db
db/*.sqlite

# Raw data snapshots (large, not code)
data/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo

# Environment variables / secrets
.env
*.env

# Mac system files
.DS_Store

# VS Code settings
.vscode/models/*.pkl
models/agent_cache.json
